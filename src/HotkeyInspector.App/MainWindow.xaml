<Window x:Class="HotkeyInspector.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
        Title="快捷键检测"
        Width="1080"
        Height="640"
        MinWidth="900"
        MinHeight="520"
        Background="{StaticResource SurfaceBrush}"
        Closing="Window_Closing"
        KeyDown="Window_KeyDown">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="快捷键检测"
                       FontSize="28"
                       FontWeight="SemiBold" />
            <TextBlock Text="检测 Windows 全局快捷键是否已被系统或其他应用占用。"
                       Foreground="#5B6472"
                       Margin="0,4,0,0" />
        </StackPanel>

        <Border Grid.Row="1"
                Background="White"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="14"
                Margin="0,0,0,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           Text="快捷键"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0" />
                <TextBox x:Name="HotkeyTextBox"
                         Grid.Row="0"
                         Grid.Column="1"
                         Text="Ctrl+Alt+K" />
                <StackPanel Grid.Row="0"
                            Grid.Column="2"
                            Orientation="Horizontal"
                            Margin="10,0,0,0">
                    <Button Content="检测" Click="CheckButton_Click" />
                    <primitives:ToggleButton x:Name="CaptureToggle"
                                             Content="捕获"
                                             MinHeight="32"
                                             Padding="14,6"
                                             Margin="0,0,8,0" />
                    <Button Content="扫描常见组合" Click="ScanButton_Click" />
                    <Button Content="导出" Click="ExportButton_Click" Margin="0" />
                </StackPanel>

                <TextBlock Grid.Row="1"
                           Grid.Column="1"
                           Grid.ColumnSpan="2"
                           Text="Windows 不提供完整的已注册快捷键列表，本工具通过临时注册快捷键判断是否占用；占用应用列会优先显示已知系统快捷键归属。"
                           Foreground="#5B6472"
                           TextWrapping="Wrap"
                           Margin="0,10,0,0" />
            </Grid>
        </Border>

        <DataGrid x:Name="ResultsGrid"
                  Grid.Row="2"
                  ItemsSource="{Binding Results}"
                  IsReadOnly="True"
                  Background="White">
            <DataGrid.Columns>
                <DataGridTextColumn Header="快捷键" Binding="{Binding Hotkey}" Width="160" />
                <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="100" />
                <DataGridTextColumn Header="占用应用" Binding="{Binding OwnerApplication}" Width="170" />
                <DataGridTextColumn Header="用途说明" Binding="{Binding Detail}" Width="*" />
                <DataGridTextColumn Header="错误码" Binding="{Binding ErrorCode}" Width="80" />
            </DataGrid.Columns>
        </DataGrid>

        <DockPanel Grid.Row="3" Margin="0,12,0,0">
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                <Button Content="复制" Click="CopyButton_Click" />
                <Button Content="清空" Click="ClearButton_Click" Margin="0" />
            </StackPanel>
            <TextBlock x:Name="StatusText"
                       Text="就绪"
                       VerticalAlignment="Center"
                       Foreground="#5B6472" />
        </DockPanel>
    </Grid>
</Window>
